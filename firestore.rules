rules_version = '2';

// FamilyShopList security rules.
// Membership source of truth: aliases/{aliasId}/members/{uid} with status 'active'.
// Join-by-code is validated entirely in rules via get() (no Cloud Functions).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function memberPath(aliasId) {
      return /databases/$(database)/documents/aliases/$(aliasId)/members/$(uid());
    }
    function isActiveMember(aliasId) {
      return signedIn()
        && exists(memberPath(aliasId))
        && get(memberPath(aliasId)).data.status == 'active';
    }
    function aliasData(aliasId) {
      return get(/databases/$(database)/documents/aliases/$(aliasId)).data;
    }
    function isOwner(aliasId) {
      return signedIn() && aliasData(aliasId).ownerId == uid();
    }
    function joinCodeOk(aliasId) {
      return request.resource.data.code == aliasData(aliasId).inviteCode;
    }
    // The invite doc for `code` exists and is still active (revocation defense:
    // Regenerate flips the old invite's active=false, so an old code is rejected
    // here even though the client also blocks it via resolveInvite).
    function inviteActive(code) {
      return exists(/databases/$(database)/documents/invites/$(code))
        && get(/databases/$(database)/documents/invites/$(code)).data.active == true;
    }
    // Content authorship integrity: a create must stamp the caller as author;
    // an update must not rewrite authorId or createdAt (DATA-MODEL.md snapshot).
    function authoredByCaller() {
      return request.resource.data.authorId == uid();
    }
    function authorFrozen() {
      return request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    // ---- user profiles ----
    match /users/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // ---- code -> alias lookup (so a non-member can resolve an invite) ----
    match /invites/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update, delete: if signedIn()
        && isOwner(request.resource.data.aliasId);
    }

    // ---- aliases ----
    match /aliases/{aliasId} {
      allow create: if signedIn() && request.resource.data.ownerId == uid();
      allow read:   if isActiveMember(aliasId);
      allow update, delete: if isOwner(aliasId);

      // membership = source of truth
      match /members/{memberId} {
        allow read: if isActiveMember(aliasId);

        // Owner bootstraps own membership right after creating the alias,
        // OR a new user self-joins with a valid, active invite code (role forced
        // to member). The written doc must identify itself with the caller uid.
        allow create: if memberId == uid()
          && request.resource.data.uid == uid()
          && request.resource.data.status == 'active'
          && (
               (isOwner(aliasId) && request.resource.data.role == 'owner')
            || (
                 joinCodeOk(aliasId)
              && inviteActive(request.resource.data.code)
              && request.resource.data.role == 'member'
            )
          );

        // Owner manages members (e.g. soft-remove via status='removed'),
        // OR a previously-removed user re-joins with a valid, active code
        // (self update, stays member, cannot rewrite uid or escalate role).
        allow update: if isOwner(aliasId)
          || (
               memberId == uid()
            && request.resource.data.uid == uid()
            && resource.data.status == 'removed'
            && joinCodeOk(aliasId)
            && inviteActive(request.resource.data.code)
            && request.resource.data.status == 'active'
            && request.resource.data.role == 'member'
          );

        allow delete: if isOwner(aliasId);
      }

      // ---- content: any active member reads; authorship is enforced on write ----
      // create must stamp the caller as author; update must not rewrite the
      // author snapshot (authorId/createdAt); delete is unrestricted for members.
      match /quickItems/{itemId} {
        allow read: if isActiveMember(aliasId);
        allow create: if isActiveMember(aliasId) && authoredByCaller();
        allow update: if isActiveMember(aliasId) && authorFrozen();
        allow delete: if isActiveMember(aliasId);
      }
      match /lists/{listId} {
        allow read, write: if isActiveMember(aliasId);
        match /items/{itemId} {
          allow read: if isActiveMember(aliasId);
          allow create: if isActiveMember(aliasId) && authoredByCaller();
          allow update: if isActiveMember(aliasId) && authorFrozen();
          allow delete: if isActiveMember(aliasId);
        }
      }
      match /wishlists/{wishlistId} {
        allow read, write: if isActiveMember(aliasId);
        match /items/{itemId} {
          allow read: if isActiveMember(aliasId);
          allow create: if isActiveMember(aliasId) && authoredByCaller();
          allow update: if isActiveMember(aliasId) && authorFrozen();
          allow delete: if isActiveMember(aliasId);
        }
      }
      // suggestions have no author snapshot — plain member read/write.
      match /suggestions/{suggestionId} {
        allow read, write: if isActiveMember(aliasId);
      }
    }
  }
}
